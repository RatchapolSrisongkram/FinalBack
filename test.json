{
	"info": {
		"name": "Admin Booking Tests",
		"description": "Test suites for Admin: Login, View, Edit, and Delete Any Booking",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "9. Admin Log-in",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"var jsonData = pm.response.json();",
							"pm.test(\"Has token\", function () {",
							"    pm.expect(jsonData.token).to.not.be.undefined;",
							"    pm.environment.set(\"admin_token\", jsonData.token);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"{{adminEmail}}\",\n    \"password\": \"{{adminPassword}}\"\n}"
				},
				"url": {
					"raw": "{{URL}}/api/v1/auth/login",
					"host": [
						"{{URL}}"
					],
					"path": [
						"api",
						"v1",
						"auth",
						"login"
					]
				}
			}
		},
		{
			"name": "10. Admin View Any Booking",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"var jsonData = pm.response.json();",
							"pm.test(\"Get Bookings success\", function () {",
							"    pm.expect(jsonData.success).to.be.true;",
							"    if(jsonData.data.length > 0) {",
							"        pm.environment.set(\"bookingId\", jsonData.data[0]._id);",
							"    }",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{admin_token}}"
					}
				],
				"url": {
					"raw": "{{URL}}/api/v1/bookings",
					"host": [
						"{{URL}}"
					],
					"path": [
						"api",
						"v1",
						"bookings"
					]
				}
			}
		},
		{
			"name": "11. Admin Edit Any Booking",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"Update success\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.be.true;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{admin_token}}"
					},
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"pickUpDate\": \"2026-12-01T00:00:00.000Z\"\n}"
				},
				"url": {
					"raw": "{{URL}}/api/v1/bookings/{{bookingId}}",
					"host": [
						"{{URL}}"
					],
					"path": [
						"api",
						"v1",
						"bookings",
						"{{bookingId}}"
					]
				}
			}
		},
		{
			"name": "12. Admin Delete Any Booking",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"Delete success\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.success).to.be.true;",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{admin_token}}"
					}
				],
				"url": {
					"raw": "{{URL}}/api/v1/bookings/{{bookingId}}",
					"host": [
						"{{URL}}"
					],
					"path": [
						"api",
						"v1",
						"bookings",
						"{{bookingId}}"
					]
				}
			}
		}
	],
	"variable": [
		{
			"key": "URL",
			"value": "http://localhost:5000"
		},
		{
			"key": "adminEmail",
			"value": "admin@example.com"
		},
		{
			"key": "adminPassword",
			"value": "123456"
		}
	]
}